<routes>
    <vType id="car" accel="2.6" decel="4.5" length="5" maxSpeed="20.12"/>

    <!-- From North: straight, left, right -->
    <route id="route_N_S" edges="N_to_C C_to_S"/>
    <route id="route_N_E" edges="N_to_C C_to_E"/>
    <route id="route_N_W" edges="N_to_C C_to_W"/>

    <!-- From South: straight, left, right -->
    <route id="route_S_N" edges="S_to_C C_to_N"/>
    <route id="route_S_W" edges="S_to_C C_to_W"/>
    <route id="route_S_E" edges="S_to_C C_to_E"/>

    <!-- From East: straight, left, right -->
    <route id="route_E_W" edges="E_to_C C_to_W"/>
    <route id="route_E_S" edges="E_to_C C_to_S"/>
    <route id="route_E_N" edges="E_to_C C_to_N"/>

    <!-- From West: straight, left, right -->
    <route id="route_W_E" edges="W_to_C C_to_E"/>
    <route id="route_W_N" edges="W_to_C C_to_N"/>
    <route id="route_W_S" edges="W_to_C C_to_S"/>

    <!--
        Target density: 100 veh/km (total across both lanes per approach)
        Speed: 20.12 m/s = 72.43 km/h
        Flow per approach: 100 * 72.43 = 7243 veh/h
        Split: 80% straight (5794), 10% left (724), 10% right (724)

        NOTE: This represents an extremely congested intersection scenario.
        SUMO will heavily queue vehicles, reducing actual speeds well below
        free-flow. The realized density will likely exceed 100 veh/km due
        to stop-and-go traffic at the signal. Vehicles that cannot be
        inserted due to lack of space will be deferred (teleported after
        default timeout). This is the stress-test scenario comparable to
        CHASM's "high density" (100 veh/km) evaluation.
    -->

    <!-- North approach: 7243 veh/h -->
    <flow id="flow_N_S" type="car" route="route_N_S"
          begin="0" end="900" vehsPerHour="5794" departLane="random" departPos="random_free"/>
    <flow id="flow_N_E" type="car" route="route_N_E"
          begin="0" end="900" vehsPerHour="724" departLane="random" departPos="random_free"/>
    <flow id="flow_N_W" type="car" route="route_N_W"
          begin="0" end="900" vehsPerHour="724" departLane="random" departPos="random_free"/>

    <!-- South approach: 7243 veh/h -->
    <flow id="flow_S_N" type="car" route="route_S_N"
          begin="0" end="900" vehsPerHour="5794" departLane="random" departPos="random_free"/>
    <flow id="flow_S_W" type="car" route="route_S_W"
          begin="0" end="900" vehsPerHour="724" departLane="random" departPos="random_free"/>
    <flow id="flow_S_E" type="car" route="route_S_E"
          begin="0" end="900" vehsPerHour="724" departLane="random" departPos="random_free"/>

    <!-- East approach: 7243 veh/h -->
    <flow id="flow_E_W" type="car" route="route_E_W"
          begin="0" end="900" vehsPerHour="5794" departLane="random" departPos="random_free"/>
    <flow id="flow_E_S" type="car" route="route_E_S"
          begin="0" end="900" vehsPerHour="724" departLane="random" departPos="random_free"/>
    <flow id="flow_E_N" type="car" route="route_E_N"
          begin="0" end="900" vehsPerHour="724" departLane="random" departPos="random_free"/>

    <!-- West approach: 7243 veh/h -->
    <flow id="flow_W_E" type="car" route="route_W_E"
          begin="0" end="900" vehsPerHour="5794" departLane="random" departPos="random_free"/>
    <flow id="flow_W_N" type="car" route="route_W_N"
          begin="0" end="900" vehsPerHour="724" departLane="random" departPos="random_free"/>
    <flow id="flow_W_S" type="car" route="route_W_S"
          begin="0" end="900" vehsPerHour="724" departLane="random" departPos="random_free"/>
</routes>
